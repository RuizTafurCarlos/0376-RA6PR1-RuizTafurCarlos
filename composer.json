{
    "name": "moncao/secure",
    "description": "MONCAO SECURE - Control de Acceso y Fichaje",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=7.4",
        "phpmailer/phpmailer": "^6.8",
        "tecnickcom/tcpdf": "^6.6"
    },
    "autoload": {
        "psr-4": {
            "MONCAO\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}